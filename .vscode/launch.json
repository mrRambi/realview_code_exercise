{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome (debug, no CORS)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "args": [
        "--web-browser-flag",
        "--disable-web-security"
      ]
    },
    {
      "name": "Chrome (release)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "flutterMode": "release"
    },
    {
      "name": "Android (debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "android"
    },
    {
      "name": "iOS (debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "ios"
    }
  ]
}
